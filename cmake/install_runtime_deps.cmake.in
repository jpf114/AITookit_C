cmake_policy(SET CMP0207 NEW)

set(installed_exe "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@/ai_toolkit_c.exe")

if(NOT EXISTS "${installed_exe}")
    message(FATAL_ERROR "Installed executable not found: ${installed_exe}")
endif()

set(vcpkg_bin_dir "@VCPKG_INSTALLED_DIR@/x64-windows/bin")

if(NOT EXISTS "${vcpkg_bin_dir}")
    message(FATAL_ERROR "Cannot locate vcpkg installed binaries directory: ${vcpkg_bin_dir}")
endif()

set(runtime_dlls
    Qt6Core.dll
    Qt6Gui.dll
    Qt6Widgets.dll
    Qt6Svg.dll
    double-conversion.dll
    pcre2-16.dll
    md4c.dll
    z.dll
    onnxruntime.dll
    onnxruntime_providers_shared.dll
    libprotobuf.dll
    libprotobuf-lite.dll
    abseil_dll.dll
    re2.dll
    opencv_core4.dll
    opencv_imgproc4.dll
    opencv_imgcodecs4.dll
    opencv_videoio4.dll
    libpng16.dll
    jpeg62.dll
    turbojpeg.dll
)

foreach(dll_name IN LISTS runtime_dlls)
    if(EXISTS "${vcpkg_bin_dir}/${dll_name}")
        file(INSTALL
            DESTINATION "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@"
            TYPE SHARED_LIBRARY
            FILES "${vcpkg_bin_dir}/${dll_name}"
        )
    endif()
endforeach()

set(qt_plugins_dir "@VCPKG_INSTALLED_DIR@/x64-windows/Qt6/plugins")

set(qt_plugin_map
    "platforms=qwindows.dll;qdirect2d.dll;qminimal.dll;qoffscreen.dll"
    "imageformats=qjpeg.dll;qsvg.dll;qgif.dll;qico.dll"
    "styles=qmodernwindowsstyle.dll"
    "iconengines=qsvgicon.dll"
)

foreach(entry IN LISTS qt_plugin_map)
    string(REGEX MATCH "^([^=]+)=(.*)$" _ "${entry}")
    set(plugin_type "${CMAKE_MATCH_1}")
    set(plugin_files "${CMAKE_MATCH_2}")
    string(REPLACE ";" ";" plugin_list "${plugin_files}")

    foreach(plugin_name IN LISTS plugin_list)
        set(plugin_path "${qt_plugins_dir}/${plugin_type}/${plugin_name}")
        if(EXISTS "${plugin_path}")
            file(INSTALL
                DESTINATION "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@/${plugin_type}"
                TYPE SHARED_LIBRARY
                FILES "${plugin_path}"
            )
        endif()
    endforeach()
endforeach()

set(vc_redist_dir "@AI_VC_REDIST_DIR@")

if(vc_redist_dir AND EXISTS "${vc_redist_dir}")
    set(vc_runtime_dlls
        concrt140.dll
        msvcp140.dll
        msvcp140_1.dll
        msvcp140_2.dll
        msvcp140_atomic_wait.dll
        msvcp140_codecvt_ids.dll
        vccorlib140.dll
        vcruntime140.dll
        vcruntime140_1.dll
        vcruntime140_threads.dll
    )
    foreach(dll_name IN LISTS vc_runtime_dlls)
        if(EXISTS "${vc_redist_dir}/${dll_name}")
            file(INSTALL
                DESTINATION "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@"
                TYPE SHARED_LIBRARY
                FILES "${vc_redist_dir}/${dll_name}"
            )
        endif()
    endforeach()
    message(STATUS "VC++ runtime DLLs installed from ${vc_redist_dir}")
else()
    message(WARNING "VC++ runtime directory not found. Install VC++ Redistributable manually.")
endif()
