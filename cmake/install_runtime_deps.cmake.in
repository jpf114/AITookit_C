cmake_policy(SET CMP0207 NEW)

set(installed_exe "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@/ai_toolkit_c.exe")

if(NOT EXISTS "${installed_exe}")
    message(FATAL_ERROR "Installed executable not found: ${installed_exe}")
endif()

if(EXISTS "@CMAKE_BINARY_DIR@/vcpkg_installed/x64-windows/bin")
    set(vcpkg_bin_dir "@CMAKE_BINARY_DIR@/vcpkg_installed/x64-windows/bin")
elseif(DEFINED ENV{VCPKG_ROOT} AND EXISTS "$ENV{VCPKG_ROOT}/installed/x64-windows/bin")
    set(vcpkg_bin_dir "$ENV{VCPKG_ROOT}/installed/x64-windows/bin")
else()
    message(FATAL_ERROR "Cannot locate vcpkg installed binaries directory")
endif()

find_program(WINDEPLOYQT_EXECUTABLE windeployqt6 HINTS "${vcpkg_bin_dir}/../tools/Qt6/bin")

if(WINDEPLOYQT_EXECUTABLE)
    message(STATUS "Running windeployqt: ${WINDEPLOYQT_EXECUTABLE}")
    execute_process(
        COMMAND "${WINDEPLOYQT_EXECUTABLE}"
            --release
            --no-translations
            --no-opengl-sw
            --dir "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@"
            "${installed_exe}"
        RESULT_VARIABLE windeployqt_result
        OUTPUT_VARIABLE windeployqt_output
        ERROR_VARIABLE windeployqt_error
    )
    if(NOT windeployqt_result EQUAL 0)
        message(WARNING "windeployqt failed (${windeployqt_result}): ${windeployqt_error}")
    else()
        message(STATUS "windeployqt completed successfully")
    endif()
else()
    message(WARNING "windeployqt not found, Qt DLLs will not be deployed automatically")
endif()

set(non_qt_dlls
    onnxruntime.dll
    opencv_core4.dll
    opencv_imgproc4.dll
    opencv_imgcodecs4.dll
    opencv_videoio4.dll
    opencv_videoio_ffmpeg4_11_0.dll
    zlib1.dll
    libpng16.dll
    jpeg62.dll
    libsharpyuv.dll
    libwebp.dll
    tiff.dll
    liblzma.dll
    bz2.dll
    zstd.dll
    abseil_dll.dll
    re2.dll
    libprotobuf.dll
    libprotobuf-lite.dll
    double-conversion.dll
    pcre2-16.dll
    harfbuzz.dll
    freetype.dll
    brotlicommon.dll
    brotlidec.dll
    md4c.dll
    icudt78.dll
    icuin78.dll
    icuuc78.dll
)

foreach(dll_name IN LISTS non_qt_dlls)
    if(EXISTS "${vcpkg_bin_dir}/${dll_name}")
        file(INSTALL
            DESTINATION "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@"
            TYPE SHARED_LIBRARY
            FILES "${vcpkg_bin_dir}/${dll_name}"
        )
    endif()
endforeach()

set(vc_redist_dir "@AI_VC_REDIST_DIR@")

if(vc_redist_dir AND EXISTS "${vc_redist_dir}")
    set(vc_runtime_dlls
        msvcp140.dll
        msvcp140_1.dll
        msvcp140_2.dll
        vcruntime140.dll
        vcruntime140_1.dll
        vcruntime140_2.dll
    )
    foreach(dll_name IN LISTS vc_runtime_dlls)
        if(EXISTS "${vc_redist_dir}/${dll_name}")
            file(INSTALL
                DESTINATION "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@"
                TYPE SHARED_LIBRARY
                FILES "${vc_redist_dir}/${dll_name}"
            )
        endif()
    endforeach()
    message(STATUS "VC++ runtime DLLs installed from ${vc_redist_dir}")
else()
    message(WARNING "VC++ runtime directory not found. Install VC++ Redistributable manually.")
endif()
